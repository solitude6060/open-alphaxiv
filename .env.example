OPEN_ALPHAXIV_STORAGE_DIR=./data
OPEN_ALPHAXIV_DATABASE_PATH=./data/open_alphaxiv.db
WEB_PORT=3100
OPEN_ALPHAXIV_CORS_ORIGIN=http://localhost:3100

# Optional OpenAI-compatible provider settings for manual configuration.
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_CHAT_MODEL=gpt-4.1
OPENAI_COMPATIBLE_EMBEDDING_MODEL=text-embedding-3-small

# Optional local Codex agent for paper Q&A. The backend process must be able to
# execute the Codex CLI and read Codex credentials. This is not browser OAuth.
OPEN_ALPHAXIV_CODEX_ENABLED=false
OPEN_ALPHAXIV_CODEX_CLI_PATH=codex
OPEN_ALPHAXIV_CODEX_MODEL=
OPEN_ALPHAXIV_CODEX_TIMEOUT_SECONDS=180
OPEN_ALPHAXIV_CODEX_SANDBOX=read-only
CODEX_HOME=
CODEX_ACCESS_TOKEN=
CODEX_API_KEY=
CODEX_AUTH_JSON_PATH=

# Used only with docker-compose.codex.yml to mount a host Codex install.
OPEN_ALPHAXIV_HOST_NODE_PREFIX=
OPEN_ALPHAXIV_HOST_CODEX_HOME=

# Optional future GitHub/Copilot integration settings.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
